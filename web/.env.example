# ConstructionOS — Web env vars. Copy to .env.local (dev) or set in Vercel project env (prod).
# Supabase (already in use; documented here for completeness)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=          # server-only; used by webhook receiver + retention cron

# Phase 22 Mux integration (https://mux.com/docs)
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MUX_SIGNING_KEY_ID=                 # 'kid' claim, from POST /system/v1/signing-keys
# MUX_SIGNING_KEY_PRIVATE=            # base64 PEM or raw PEM
# MUX_WEBHOOK_SECRET=                 # verify Mux-Signature header (D-32). Rotate in Mux dashboard + here.
# WORKER_SHARED_SECRET=               # same value as app.ffmpeg_worker_secret GUC (22-01 Task 3)
