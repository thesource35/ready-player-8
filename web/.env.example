# ConstructionOS — Web env vars
# ====================================================================
# Copy this file to `.env.local` (dev) or set values in the Vercel
# project env (prod). Variables prefixed `NEXT_PUBLIC_` are exposed to
# browser bundles; everything else is server-only and must NEVER be
# imported into a Client Component.
#
# Last audited: 2026-04-27 (backlog 999.5 (h) working-tree triage).

# ====================================================================
# REQUIRED — app will not work without these
# ====================================================================

# --- SUPABASE (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=                                  # legacy alias for publishable key; either works
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_KEY                   # server-only; bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=                                      # legacy alias for secret key; either works

# --- ANTHROPIC (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY                         # used by /api/chat (Claude conversations)

# ====================================================================
# FEATURE-GATED — required only if the feature is in use
# ====================================================================

# --- MAPBOX (https://mapbox.com — only needed for /maps live page)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# --- MUX (https://mux.com/docs — required for Phase 22 video upload + playback)
MUX_TOKEN_ID=                                                   # API token id from Mux dashboard
MUX_TOKEN_SECRET=                                               # API token secret
MUX_SIGNING_KEY_ID=                                             # 'kid' claim, POST /system/v1/signing-keys
MUX_SIGNING_KEY_PRIVATE=                                        # base64-encoded PEM or raw PEM
MUX_WEBHOOK_SECRET=                                             # verifies Mux-Signature header (D-32)
WORKER_SHARED_SECRET=                                           # matches app.ffmpeg_worker_secret GUC

# --- RESEND (https://resend.com — required for transactional email)
RESEND_API_KEY=re_YOUR_RESEND_KEY                               # used by /api/reports/cron, /api/reports/schedule, portalEmail.tsx
NEXT_PUBLIC_APP_URL=https://constructionos.com                  # rendered into email links; falls back to constructionos.com

# --- VERCEL CRON (https://vercel.com/docs/cron-jobs)
CRON_SECRET=                                                    # required by /api/reports/cron auth check; set as Vercel cron header

# --- EXPORT FEATURE (admin allowlist)
EXPORT_ALLOWED_EMAILS=                                          # comma-separated list of admin emails who can hit /api/export

# ====================================================================
# BILLING — pick ONE provider; the others can stay blank
# ====================================================================
# (TODO 999.5 follow-up: confirm which provider is the live one.
#  Code references all three but production should only use one.)

# --- PADDLE (https://paddle.com)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox                                  # 'sandbox' | 'production'

# --- COINBASE COMMERCE (https://commerce.coinbase.com)
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- SQUARE (https://developer.squareup.com)
# NOTE: code references these in /api/billing/webhook/route.ts; verify if Square is the live integration
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

# ====================================================================
# OPTIONAL / FUTURE
# ====================================================================

# --- POSTHOG (https://posthog.com — observability; currently referenced in /api/reports/metrics as commented-out)
POSTHOG_API_KEY=                                                # uncomment when PostHog is wired

# --- FIREBASE (legacy / unclear if still in use; candidate for removal in 999.5 cleanup)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- COINGECKO (free, no key needed — kept for documentation)
# No env var required; called directly from server-side code.

# ====================================================================
# AUTO-INJECTED BY VERCEL — do not set manually
# ====================================================================
# VERCEL_OIDC_TOKEN          (Vercel sets this for OIDC-authenticated build runs)
# VERCEL_ENV                 ('development' | 'preview' | 'production')
# VERCEL_URL                 (deployment URL)
